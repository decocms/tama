{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"types": ["bun", "vite/client", "@cloudflare/workers-types"],
		"lib": ["ESNext", "DOM"],
		"jsx": "react-jsx",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"allowImportingTsExtensions": true,
		"noEmit": true,
		"baseUrl": ".",
		"paths": {
			"@/*": ["./web/*"]
		}
	},
	"include": ["api/**/*", "web/**/*"],
	"exclude": ["node_modules", "dist"]
}
