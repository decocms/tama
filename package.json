{
	"name": "tama",
	"version": "0.1.0",
	"description": "A health-record agent for your pet — one timeline, a medicine timetable, and assets intake. Cloudflare Workers + D1 + R2.",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "concurrently -k -n web,worker -c cyan,magenta \"bun run dev:web\" \"bun run dev:worker\"",
		"dev:pull": "bun run sync:from-prod && bun run dev",
		"dev:web": "vite build --watch",
		"dev:worker": "wrangler dev",
		"build": "vite build",
		"deploy": "bun run build && wrangler deploy",
		"db:generate": "drizzle-kit generate",
		"db:migrate:local": "wrangler d1 migrations apply myvet --local",
		"db:migrate:remote": "wrangler d1 migrations apply myvet --remote",
		"db:studio:local": "drizzle-kit studio",
		"sync:to-prod": "bun run scripts/sync-to-prod.ts",
		"sync:from-prod": "bun run scripts/sync-from-prod.ts",
		"seed:example": "bun run scripts/seed-example.ts",
		"update": "bun run scripts/update.ts",
		"db:gc": "bun run scripts/db-gc.ts",
		"db:gc:dry": "bun run scripts/db-gc.ts --dry-run",
		"ci:check": "bunx biome ci .",
		"check": "tsc --noEmit",
		"test": "bun test",
		"fmt": "biome format --write .",
		"lint": "biome lint --write ."
	},
	"dependencies": {
		"@base-ui/react": "^1.2.0",
		"@decocms/runtime": "^1.2.10",
		"@hookform/resolvers": "^5.2.2",
		"@modelcontextprotocol/ext-apps": "^1.1.2",
		"@modelcontextprotocol/sdk": "^1.26.0",
		"@tailwindcss/vite": "^4.2.1",
		"@tanstack/history": "^1.133.5",
		"@tanstack/react-query": "^5.90.21",
		"@tanstack/react-router": "^1.133.5",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"date-fns": "^4.1.0",
		"drizzle-orm": "^0.36.4",
		"embla-carousel-react": "^8.6.0",
		"input-otp": "^1.4.2",
		"lucide-react": "^0.576.0",
		"next-themes": "^0.4.6",
		"radix-ui": "^1.4.3",
		"react": "^19.2.0",
		"react-day-picker": "^9.14.0",
		"react-dom": "^19.2.0",
		"react-hook-form": "^7.71.2",
		"react-resizable-panels": "^4",
		"recharts": "2.15.4",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.5.0",
		"tailwindcss": "^4.2.1",
		"vaul": "^1.1.2",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.14",
		"@cloudflare/workers-types": "^4.20250109.0",
		"@types/bun": "^1.3.8",
		"@types/react": "^19.2.2",
		"@types/react-dom": "^19.2.2",
		"@vitejs/plugin-react": "^5.0.4",
		"babel-plugin-react-compiler": "^1.0.0",
		"concurrently": "^9.2.1",
		"drizzle-kit": "^0.30.1",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vite-plugin-singlefile": "^2.3.0",
		"wrangler": "^4.0.0"
	}
}
